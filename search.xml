      <title>MathJax_Basic01</title>
      <link href="/2022/10/12/MathJax_Basic01/"/>
      <url>/2022/10/12/MathJax_Basic01/</url>
      
        <content type="html"><![CDATA[<font size="6"><b>This is a MarkDown Notes for learning MathJax.</b></font><h2 id="MathJax-Location"><a href="#MathJax-Location" class="headerlink" title="MathJax Location"></a>MathJax Location</h2><div class="table-container"><table><thead><tr><th style="text-align:center">位置</th><th style="text-align:center">代码</th><th style="text-align:center">示例</th></tr></thead><tbody><tr><td style="text-align:center">行内插入</td><td style="text-align:center"><script type="math/tex">...</script></td><td style="text-align:center">$\sum<em>{i=0}^N\int</em>{a}^{b}g(t,i)\text{d}t$</td></tr><tr><td style="text-align:center">自成段落</td><td style="text-align:center">$$$…$$$</td></tr></tbody></table></div><script type="math/tex; mode=display">\sum_{i=0}^N\int_{a}^{b}g(t,i)\text{d}t</script><h2 id="消除二义性"><a href="#消除二义性" class="headerlink" title="消除二义性"></a>消除二义性</h2><div class="table-container"><table><thead><tr><th style="text-align:center">位置</th><th style="text-align:center">代码</th><th style="text-align:center">示例</th></tr></thead><tbody><tr><td style="text-align:center">未使用<code>&#123;&#125;</code></td><td style="text-align:center"><script type="math/tex">x^12</script></td><td style="text-align:center">$x^12$</td></tr><tr><td style="text-align:center">使用<code>&#123;&#125;</code></td><td style="text-align:center"><script type="math/tex">x^{12}</script></td><td style="text-align:center">$x^{12}$</td></tr></tbody></table></div><h2 id="希腊字母"><a href="#希腊字母" class="headerlink" title="希腊字母"></a>希腊字母</h2><div class="table-container"><table><thead><tr><th style="text-align:center">ID</th><th style="text-align:center">大写</th><th style="text-align:center">代码</th><th style="text-align:center">小写</th><th style="text-align:center">代码</th><th style="text-align:center">ID</th><th style="text-align:center">大写</th><th style="text-align:center">代码</th><th style="text-align:center">小写</th><th style="text-align:center">代码</th></tr></thead><tbody><tr><td style="text-align:center">1</td><td style="text-align:center">$\Alpha$</td><td style="text-align:center"><script type="math/tex">\Alpha</script></td><td style="text-align:center">$\alpha$</td><td style="text-align:center"><script type="math/tex">\alpha</script></td><td style="text-align:center">13</td><td style="text-align:center">$\Lambda$</td><td style="text-align:center"><script type="math/tex">\Lambda</script></td><td style="text-align:center">$\lambda$</td><td style="text-align:center"><script type="math/tex">\lambda</script></td></tr><tr><td style="text-align:center">2</td><td style="text-align:center">$\Beta$</td><td style="text-align:center"><script type="math/tex">\Beta</script></td><td style="text-align:center">$\beta$</td><td style="text-align:center"><script type="math/tex">\beta</script></td><td style="text-align:center">14</td><td style="text-align:center">$\Mu$</td><td style="text-align:center"><script type="math/tex">\Mu</script></td><td style="text-align:center">$\mu$</td><td style="text-align:center"><script type="math/tex">\mu</script></td></tr><tr><td style="text-align:center">3</td><td style="text-align:center">$\Gamma$</td><td style="text-align:center"><script type="math/tex">\Gamma</script></td><td style="text-align:center">$\gamma$</td><td style="text-align:center"><script type="math/tex">\gamma</script></td><td style="text-align:center">15</td><td style="text-align:center">$\Nu$</td><td style="text-align:center"><script type="math/tex">\Nu</script></td><td style="text-align:center">$\nu$</td><td style="text-align:center"><script type="math/tex">\nu</script></td></tr><tr><td style="text-align:center">4</td><td style="text-align:center">$\Delta$</td><td style="text-align:center"><script type="math/tex">\Delta</script></td><td style="text-align:center">$\delta$</td><td style="text-align:center"><script type="math/tex">\delta</script></td><td style="text-align:center">16</td><td style="text-align:center">$\Xi$</td><td style="text-align:center"><script type="math/tex">\Xi</script></td><td style="text-align:center">$\xi$</td><td style="text-align:center"><script type="math/tex">\xi</script></td></tr><tr><td style="text-align:center">5</td><td style="text-align:center">$\Epsilon$</td><td style="text-align:center"><script type="math/tex">\Epsilon</script></td><td style="text-align:center">$\epsilon$</td><td style="text-align:center"><script type="math/tex">\epsilon</script></td><td style="text-align:center">17</td><td style="text-align:center">$\Omicron$</td><td style="text-align:center"><script type="math/tex">\Omicron</script></td><td style="text-align:center">$\omicron$</td><td style="text-align:center"><script type="math/tex">\omicron</script></td></tr><tr><td style="text-align:center">6</td><td style="text-align:center">$\Zeta$</td><td style="text-align:center"><script type="math/tex">\Zeta</script></td><td style="text-align:center">$\zeta$</td><td style="text-align:center"><script type="math/tex">\zeta</script></td><td style="text-align:center">18</td><td style="text-align:center">$\Pi$</td><td style="text-align:center"><script type="math/tex">\Pi</script></td><td style="text-align:center">$\pi$</td><td style="text-align:center"><script type="math/tex">\pi</script></td></tr><tr><td style="text-align:center">7</td><td style="text-align:center">$\Eta$</td><td style="text-align:center"><script type="math/tex">\Eta</script></td><td style="text-align:center">$\eta$</td><td style="text-align:center"><script type="math/tex">\eta</script></td><td style="text-align:center">19</td><td style="text-align:center">$\Rho$</td><td style="text-align:center"><script type="math/tex">\Rho</script></td><td style="text-align:center">$\rho$</td><td style="text-align:center"><script type="math/tex">\rho</script></td></tr><tr><td style="text-align:center">8</td><td style="text-align:center">$\Theta$</td><td style="text-align:center"><script type="math/tex">\Theta</script></td><td style="text-align:center">$\theta$</td><td style="text-align:center"><script type="math/tex">\theta</script></td><td style="text-align:center">20</td><td style="text-align:center">$\Sigma$</td><td style="text-align:center"><script type="math/tex">\Sigma</script></td><td style="text-align:center">$\sigma$</td><td style="text-align:center"><script type="math/tex">\sigma</script></td></tr><tr><td style="text-align:center">9</td><td style="text-align:center">$\Iota$</td><td style="text-align:center"><script type="math/tex">\Iota</script></td><td style="text-align:center">$\iota$</td><td style="text-align:center"><script type="math/tex">\iota</script></td><td style="text-align:center">21</td><td style="text-align:center">$\Tau$</td><td style="text-align:center"><script type="math/tex">\Tau</script></td><td style="text-align:center">$\tau$</td><td style="text-align:center"><script type="math/tex">\tau</script></td></tr><tr><td style="text-align:center">10</td><td style="text-align:center">$\Kappa$</td><td style="text-align:center"><script type="math/tex">\Kappa</script></td><td style="text-align:center">$\kappa$</td><td style="text-align:center"><script type="math/tex">\kappa</script></td><td style="text-align:center">22</td><td style="text-align:center">$\Upsilon$</td><td style="text-align:center"><script type="math/tex">\Upsilon</script></td><td style="text-align:center">$\upsilon$</td><td style="text-align:center"><script type="math/tex">\upsilon</script></td></tr><tr><td style="text-align:center">11</td><td style="text-align:center">$\Phi$</td><td style="text-align:center"><script type="math/tex">\Phi</script></td><td style="text-align:center">$\phi$</td><td style="text-align:center"><script type="math/tex">\phi</script></td><td style="text-align:center">23</td><td style="text-align:center">$\Chi$</td><td style="text-align:center"><script type="math/tex">\Chi</script></td><td style="text-align:center">$\chi$</td><td style="text-align:center"><script type="math/tex">\chi</script></td></tr><tr><td style="text-align:center">12</td><td style="text-align:center">$\Psi$</td><td style="text-align:center"><script type="math/tex">\Psi</script></td><td style="text-align:center">$\psi$</td><td style="text-align:center"><script type="math/tex">\psi</script></td><td style="text-align:center">24</td><td style="text-align:center">$\Omega$</td><td style="text-align:center"><script type="math/tex">\Omega</script></td><td style="text-align:center">$\omega$</td><td style="text-align:center"><script type="math/tex">\omega</script></td></tr></tbody></table></div><h2 id="运算符号"><a href="#运算符号" class="headerlink" title="运算符号"></a>运算符号</h2><div class="table-container"><table><thead><tr><th style="text-align:center">符号</th><th style="text-align:center">代码</th><th style="text-align:center">符号</th><th style="text-align:center">代码</th><th style="text-align:center">符号</th><th style="text-align:center">代码</th></tr></thead><tbody><tr><td style="text-align:center">$\infty$</td><td style="text-align:center"><script type="math/tex">\infty</script></td><td style="text-align:center">$\sim$</td><td style="text-align:center"><script type="math/tex">\sim</script></td><td style="text-align:center">$\land$</td><td style="text-align:center"><script type="math/tex">\land</script></td></tr><tr><td style="text-align:center">$\star$</td><td style="text-align:center"><script type="math/tex">\star</script></td><td style="text-align:center">$\simeq$</td><td style="text-align:center"><script type="math/tex">\simeq</script></td><td style="text-align:center">$\lor$</td><td style="text-align:center"><script type="math/tex">\lor</script></td></tr><tr><td style="text-align:center">$\ast$</td><td style="text-align:center"><script type="math/tex">\ast</script></td><td style="text-align:center">$\cong$</td><td style="text-align:center"><script type="math/tex">\cong</script></td><td style="text-align:center">$\forall$</td><td style="text-align:center"><script type="math/tex">\forall</script></td></tr><tr><td style="text-align:center">$\bullet$</td><td style="text-align:center"><script type="math/tex">\bullet</script></td><td style="text-align:center">$\equiv$</td><td style="text-align:center"><script type="math/tex">\equiv</script></td><td style="text-align:center">$\nabla$</td><td style="text-align:center"><script type="math/tex">\nabla</script></td></tr><tr><td style="text-align:center">$\cdot$</td><td style="text-align:center"><script type="math/tex">\cdot</script></td><td style="text-align:center">$\approx$</td><td style="text-align:center"><script type="math/tex">\approx</script></td><td style="text-align:center">$\partial$</td><td style="text-align:center"><script type="math/tex">\partial</script></td></tr><tr><td style="text-align:center">$\circ$</td><td style="text-align:center"><script type="math/tex">\circ</script></td><td style="text-align:center">$\oplus$</td><td style="text-align:center"><script type="math/tex">\oplus</script></td><td style="text-align:center">$\exists$</td><td style="text-align:center"><script type="math/tex">\exists</script></td></tr><tr><td style="text-align:center">$\top$</td><td style="text-align:center"><script type="math/tex">\top</script></td><td style="text-align:center">$\bot$</td><td style="text-align:center"><script type="math/tex">\bot</script></td><td style="text-align:center">$\vdash$</td><td style="text-align:center"><script type="math/tex">\vdash</script></td></tr><tr><td style="text-align:center">$\vDash$</td><td style="text-align:center"><script type="math/tex">\vDash</script></td><td style="text-align:center">$\lnot$</td><td style="text-align:center"><script type="math/tex">\lnot</script></td><td style="text-align:center">$\prec$</td><td style="text-align:center"><script type="math/tex">\prec</script></td></tr><tr><td style="text-align:center">${n+1 \choose 2k}$</td><td style="text-align:center"><script type="math/tex">{n+1 \choose 2k}</script></td><td style="text-align:center">$\binom{n+1}{2k}$</td><td style="text-align:center"><script type="math/tex">\binom{n+1}{2k}</script></td></tr></tbody></table></div><h1 id><a href="#" class="headerlink" title="#"></a>#</h1>]]></content>
      
      
      
